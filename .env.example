# CognitiveEvolve quickstart local provider config
# Copy to .env or run: cogev quickstart "your problem"
COGEV_LLM_PROVIDER=litellm
COGEV_LLM_MODEL=provider/model-id
COGEV_LLM_API_BASE=https://your-provider.example/v1
COGEV_LLM_API_KEY=replace-with-your-upstream-model-api-key
COGEV_LLM_MAX_CONCURRENT=1
COGEV_NEXUS_MAX_ROUNDS=2

# Optional OpenAI-compatible local service wrapper
COGEV_SERVER_HOST=127.0.0.1
COGEV_SERVER_PORT=8765
COGEV_SERVER_PUBLIC_BASE_URL=http://127.0.0.1:8765/v1
COGEV_SERVER_REQUIRE_AUTH=true
COGEV_SERVER_API_KEY=ce-local-dev-key-change-me
COGEV_API_TASK_ROOT=.cogev/api-runs
