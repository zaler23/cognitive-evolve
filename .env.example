# CognitiveEvolve v2.0 local service configuration
# This file contains local development defaults only. Replace the provider key
# and the frontend service key before any shared or public deployment.

# ----- Upstream model provider used internally by CognitiveEvolve -----
# Configure any LiteLLM-supported or direct OpenAI-compatible upstream.
# Set COGEV_LLM_PROVIDER=direct_http when the endpoint should receive plain /v1/chat/completions requests.
# Examples:
#   COGEV_LLM_MODEL=provider/model-id
#   COGEV_LLM_API_BASE=https://your-provider.example/v1
#   COGEV_LLM_API_KEY=replace-with-your-upstream-model-api-key
COGEV_LLM_PROVIDER=litellm
COGEV_LLM_MODEL=provider/model-id
COGEV_LLM_API_BASE=https://your-provider.example/v1
COGEV_LLM_API_KEY=replace-with-your-upstream-model-api-key
COGEV_LLM_TEMPERATURE=0.2
# Leave COGEV_LLM_MAX_TOKENS unset unless you intentionally want one global override.
COGEV_LLM_LIGHT_MAX_TOKENS=4096
COGEV_LLM_LONG_MAX_TOKENS=32768
COGEV_LLM_RETRY_MAX_TOKENS=32768
COGEV_LLM_EMPTY_RETRY_PROMPT_CHARS=24000
COGEV_LLM_TIMEOUT=120
COGEV_LLM_RETRY_ATTEMPTS=5
COGEV_LLM_BUDGET_USD=2.00

# ----- Frontend-facing CognitiveEvolve OpenAI-compatible service -----
# Cherry Studio / OpenWebUI / Continue / Roo Code should use this key, not the
# upstream provider key above.
COGEV_SERVER_HOST=127.0.0.1
COGEV_SERVER_PORT=8765
COGEV_SERVER_PUBLIC_BASE_URL=http://127.0.0.1:8765/v1
COGEV_SERVER_REQUIRE_AUTH=true
# Loopback-only development placeholder. Non-loopback/public binds refuse this
# value; replace with a private high-entropy key before setting
# COGEV_SERVER_HOST=0.0.0.0 or wildcard CORS.
COGEV_SERVER_API_KEY=ce-local-dev-key-change-me
COGEV_SERVE_MODELS=cognitive-evolve-one-shot,cognitive-evolve-one-shot-deep,cognitive-evolve-one-shot-ultra,cognitive-evolve-one-shot-exhaustive
COGEV_DEFAULT_SERVE_MODEL=cognitive-evolve-one-shot-deep
# Relative paths are resolved under COGEV_RUNTIME_ROOT, defaulting to ~/.cognitive-evolve.
COGEV_API_TASK_ROOT=.cogev/api-runs
COGEV_CORS_ALLOW_ORIGINS=*
# Local API resource guards. Keep reverse-proxy limits at least as strict for
# shared deployments.
COGEV_API_MAX_REQUEST_BYTES=4194304
COGEV_API_RATE_LIMIT_PER_MINUTE=120
COGEV_API_JOB_TTL_SECONDS=86400
COGEV_API_MAX_TRACKED_JOBS=1000

# ----- Internal evolution caps per frontend model -----
# 0 means adaptive Nexus profile. Set a positive value only for an explicit hard cap.
COGEV_MODEL_ROUND_CAP_COGNITIVE_EVOLVE_ONE_SHOT=0
COGEV_MODEL_ROUND_CAP_COGNITIVE_EVOLVE_ONE_SHOT_DEEP=0
COGEV_MODEL_ROUND_CAP_COGNITIVE_EVOLVE_ONE_SHOT_ULTRA=0
COGEV_MODEL_ROUND_CAP_COGNITIVE_EVOLVE_ONE_SHOT_EXHAUSTIVE=0

# ----- Long-running LLM governor and retry behavior -----
COGEV_LLM_MAX_CONCURRENT=3
# 0 disables the minute bucket; set provider-specific values for production.
COGEV_LLM_RPM=0
COGEV_LLM_TPM=0
COGEV_LLM_RETRY_BASE_SLEEP=1
COGEV_LLM_RETRY_MAX_SLEEP=8
COGEV_LLM_RETRY_JITTER=0
COGEV_LLM_JSON_RETRY_ATTEMPTS=5

# ----- Internal evolution profiles and stop behavior -----
# balanced | deep | ultra | exhaustive
COGEV_EVOLUTION_PROFILE=balanced
# adaptive_until_solved | max_rounds | llm_after_minimum | convergence_or_max_rounds
# Legacy budget_guarded is accepted as an alias for adaptive_until_solved.
COGEV_STOP_POLICY=adaptive_until_solved
# Optional minimum before the model/verifier stop gate can close the run.
COGEV_MIN_ROUNDS_BEFORE_STOP=1
# Safety checkpoints for adaptive profiles. Old COGEV_NEXUS_PROFILE_*_ROUNDS is ignored by default.
COGEV_NEXUS_PROFILE_EXHAUSTIVE_SAFETY_ROUNDS=240
# Optional dynamic candidate floor. Old COGEV_NEXUS_PROFILE_*_CANDIDATES is ignored by default.
COGEV_NEXUS_PROFILE_EXHAUSTIVE_MIN_CANDIDATES=
# Optional global mutation width fallback; profile-specific *_BRANCH_FACTOR overrides it.
# Old COGEV_MUTATION_BRANCH_FACTOR and COGEV_ACTIVE_POOL_LIMIT are ignored by default.
COGEV_NEXUS_BRANCH_FACTOR=
# Nexus ranking is relative + multihead.  Do not configure legacy pairwise/Elo
# inheritance penalties here; mutation value is stored on CandidateGenome scores,
# lineage, archive fate, and policy-guided parent selection.
# auto = inline for small checkpoints, background single-writer thread for large long-run snapshots.
COGEV_CHECKPOINT_WRITE_MODE=auto
COGEV_CHECKPOINT_ASYNC_MIN_UNITS=120
COGEV_STREAM_HEARTBEAT_SECONDS=15
# 0 leaves streaming open while the run is active. Set a positive value to close
# long SSE connections and rely on /v1/cogev/jobs durable polling.
COGEV_STREAM_MAX_SECONDS=0

# ----- Optional Adaptive Evidence Layer -----
# Default source install behavior remains baseline unless enabled here or in task.yaml.
COGEV_ADAPTIVE_ENABLED=false
# observe | selection | local_evaluation. observe records spatial evidence without changing parent selection.
COGEV_SPATIAL_MODE=observe
# Optional task-specific external evaluator command. Use {candidate_path} as the candidate JSON placeholder.
COGEV_EXTERNAL_EVALUATOR_COMMAND=
COGEV_EXTERNAL_EVALUATOR_TIMEOUT=30

# ----- Optional external evidence gateway -----
# Public-release default blocks localhost/private-network endpoints to reduce SSRF risk.
# Set COGEV_EVIDENCE_HTTP_ALLOW_PRIVATE=1 only for trusted local development.
COGEV_EVIDENCE_HTTP_ENDPOINT=
COGEV_EVIDENCE_HTTP_BEARER_TOKEN=
COGEV_EVIDENCE_HTTP_TIMEOUT=10
COGEV_EVIDENCE_HTTP_MAX_RESPONSE_BYTES=1000000
COGEV_EVIDENCE_HTTP_MAX_JSON_DEPTH=24
COGEV_EVIDENCE_HTTP_ALLOW_PRIVATE=false

# Optional MCP/stdio evidence adapter. This command is split without shell=True;
# it should read one JSON request from stdin and write one JSON object to stdout.
COGEV_EVIDENCE_MCP_COMMAND=
COGEV_EVIDENCE_MCP_TIMEOUT=10
COGEV_EVIDENCE_MCP_MAX_RESPONSE_BYTES=1000000
COGEV_EVIDENCE_MCP_MAX_JSON_DEPTH=24

# ----- Optional strict LLM cost gates -----
# Stage budgets are advisory and task-type-aware by default, so performance remains the baseline.
COGEV_LLM_STAGE_BUDGET_STRICT=false
