# Test/demo-only configuration. It uses deterministic fixture responses instead
# of a real model provider and should not be used for production quality output.
COGEV_LLM_PROVIDER=fixture
COGEV_LLM_FIXTURE=tests/fixtures/llm_fixture.json
COGEV_SERVER_HOST=127.0.0.1
COGEV_SERVER_PORT=8765
COGEV_SERVER_PUBLIC_BASE_URL=http://127.0.0.1:8765/v1
COGEV_SERVER_REQUIRE_AUTH=true
COGEV_SERVER_API_KEY=ce-local-dev-key-change-me
COGEV_SERVE_MODELS=cognitive-evolve-one-shot,cognitive-evolve-one-shot-deep,cognitive-evolve-one-shot-ultra
COGEV_DEFAULT_SERVE_MODEL=cognitive-evolve-one-shot-deep
# Relative paths are resolved under COGEV_RUNTIME_ROOT, defaulting to ~/.cognitive-evolve.
COGEV_API_TASK_ROOT=.cogev/api-runs
