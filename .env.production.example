# CognitiveEvolve v2.0 generic production service configuration
# Copy this file outside source control as .env, then replace every placeholder.
# The public repository intentionally contains no local private application relay, no
# provider-specific secret, and no deployment-specific credential.

# ----- Upstream model provider used internally by CognitiveEvolve -----
# Supported production paths:
#   1. LiteLLM provider IDs, for example provider/model-id.
#   2. Direct OpenAI-compatible HTTP by setting COGEV_LLM_PROVIDER=direct_http.
# The direct HTTP provider expects COGEV_LLM_API_BASE to expose /v1/chat/completions.
COGEV_LLM_PROVIDER=litellm
COGEV_LLM_MODEL=provider/model-id
COGEV_LLM_API_BASE=https://your-provider.example/v1
COGEV_LLM_API_KEY=replace-with-your-upstream-model-api-key
COGEV_LLM_TEMPERATURE=0.2
COGEV_LLM_LIGHT_MAX_TOKENS=4096
COGEV_LLM_LONG_MAX_TOKENS=32768
COGEV_LLM_RETRY_MAX_TOKENS=32768
COGEV_LLM_EMPTY_RETRY_PROMPT_CHARS=24000
COGEV_LLM_TIMEOUT=120
COGEV_LLM_RETRY_ATTEMPTS=5
COGEV_LLM_BUDGET_USD=10.00
COGEV_LLM_MAX_CONCURRENT=3
COGEV_LLM_RPM=0
COGEV_LLM_TPM=0
COGEV_LLM_RETRY_BASE_SLEEP=1
COGEV_LLM_RETRY_MAX_SLEEP=8
COGEV_LLM_RETRY_JITTER=0
COGEV_LLM_JSON_RETRY_ATTEMPTS=5

# ----- Frontend-facing CognitiveEvolve OpenAI-compatible service -----
# Frontends use COGEV_SERVER_API_KEY. Never expose COGEV_LLM_API_KEY to clients.
COGEV_SERVER_HOST=0.0.0.0
COGEV_SERVER_PORT=8765
COGEV_SERVER_PUBLIC_BASE_URL=https://cognitive-evolve.example/v1
COGEV_SERVER_REQUIRE_AUTH=true
COGEV_SERVER_API_KEY=replace-with-high-entropy-service-api-key
COGEV_SERVE_MODELS=cognitive-evolve-one-shot,cognitive-evolve-one-shot-deep,cognitive-evolve-one-shot-ultra,cognitive-evolve-one-shot-exhaustive
COGEV_DEFAULT_SERVE_MODEL=cognitive-evolve-one-shot-deep
COGEV_API_TASK_ROOT=.cogev/api-runs
COGEV_CORS_ALLOW_ORIGINS=https://your-frontend.example
COGEV_CORS_ALLOW_CREDENTIALS=true
COGEV_API_MAX_REQUEST_BYTES=4194304
COGEV_API_RATE_LIMIT_PER_MINUTE=120
COGEV_API_JOB_TTL_SECONDS=86400
COGEV_API_MAX_TRACKED_JOBS=1000

# ----- Adaptive evolution and early-stop behavior -----
# The runtime may stop early only for candidate_ready_for_external_review or
# diminishing_returns_checkpoint, both of which still require human/external review.
COGEV_EVOLUTION_PROFILE=balanced
COGEV_STOP_POLICY=adaptive_until_solved
COGEV_MIN_ROUNDS_BEFORE_STOP=1
COGEV_NEXUS_PROFILE_EXHAUSTIVE_SAFETY_ROUNDS=240
COGEV_NEXUS_PROFILE_EXHAUSTIVE_MIN_CANDIDATES=
COGEV_NEXUS_BRANCH_FACTOR=
COGEV_MODEL_ROUND_CAP_COGNITIVE_EVOLVE_ONE_SHOT=0
COGEV_MODEL_ROUND_CAP_COGNITIVE_EVOLVE_ONE_SHOT_DEEP=0
COGEV_MODEL_ROUND_CAP_COGNITIVE_EVOLVE_ONE_SHOT_ULTRA=0
COGEV_MODEL_ROUND_CAP_COGNITIVE_EVOLVE_ONE_SHOT_EXHAUSTIVE=0
COGEV_CHECKPOINT_WRITE_MODE=auto
COGEV_CHECKPOINT_ASYNC_MIN_UNITS=120
COGEV_STREAM_HEARTBEAT_SECONDS=15
COGEV_STREAM_MAX_SECONDS=0

# ----- Optional Adaptive Evidence Layer -----
COGEV_ADAPTIVE_ENABLED=false
COGEV_SPATIAL_MODE=observe
COGEV_EXTERNAL_EVALUATOR_COMMAND=
COGEV_EXTERNAL_EVALUATOR_TIMEOUT=30

# ----- Optional external evidence adapters -----
COGEV_EVIDENCE_HTTP_ENDPOINT=
COGEV_EVIDENCE_HTTP_BEARER_TOKEN=
COGEV_EVIDENCE_HTTP_TIMEOUT=10
COGEV_EVIDENCE_HTTP_MAX_RESPONSE_BYTES=1000000
COGEV_EVIDENCE_HTTP_MAX_JSON_DEPTH=24
COGEV_EVIDENCE_HTTP_ALLOW_PRIVATE=false
COGEV_EVIDENCE_MCP_COMMAND=
COGEV_EVIDENCE_MCP_TIMEOUT=10
COGEV_EVIDENCE_MCP_MAX_RESPONSE_BYTES=1000000
COGEV_EVIDENCE_MCP_MAX_JSON_DEPTH=24

# ----- Optional strict LLM cost gates -----
COGEV_LLM_STAGE_BUDGET_STRICT=false
